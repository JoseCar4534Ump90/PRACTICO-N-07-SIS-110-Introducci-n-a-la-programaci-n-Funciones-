#include <iostream>
#include <cmath> // Para la funcion sqrt()

using namespace std;

// Prototipo del procedimiento
void RESOLVER_CUADRATICA(float a, float b, float c);

int main() {
    float a, b, c;
    
    cout << "--- 8. RESOLVER ECUACION CUADRATICA ---" << endl;
    cout << "Para la forma ax^2 + bx + c = 0" << endl;
    cout << "Ingrese los coeficientes a, b y c (separados por espacio): ";
    cin >> a >> b >> c;
    
    RESOLVER_CUADRATICA(a, b, c);
    
    return 0;
}

// Implementacion del procedimiento
void RESOLVER_CUADRATICA(float a, float b, float c) {
    if (a == 0) {
        cout << "Si a=0, no es una ecuacion cuadratica, es lineal." << endl;
        return;
    }

    float discriminante = (b * b) - (4 * a * c);
    
    cout << "\nResultados:" << endl;
    if (discriminante > 0) {
        // Dos raices reales
        float x1 = (-b + sqrt(discriminante)) / (2 * a);
        float x2 = (-b - sqrt(discriminante)) / (2 * a);
        cout << "Caso: Dos raices reales y distintas." << endl;
        cout << "x1 = " << x1 << endl;
        cout << "x2 = " << x2 << endl;
    } 
    else if (discriminante == 0) {
        // Una raiz doble
        float x = -b / (2 * a);
        cout << "Caso: Una raiz doble (identica)." << endl;
        cout << "x1 = x2 = " << x << endl;
    } 
    else {
        // Raices complejas
        float parteReal = -b / (2 * a);
        // Sacamos la raiz positiva del discriminante negativo para la parte imaginaria
        float parteImaginaria = sqrt(-discriminante) / (2 * a);
        
        cout << "Caso: Dos raices complejas conjugadas." << endl;
        cout << "x1 = " << parteReal << " + " << parteImaginaria << "i" << endl;
        cout << "x2 = " << parteReal << " - " << parteImaginaria << "i" << endl;
    }
}
