#include <iostream>
#include <string>

using namespace std;

// Prototipo del procedimiento
void LITERAL(int dia, int mes, int anio);

int main() {
    int d, m, a;
    
    cout << "--- 6. FECHA LITERAL ---" << endl;
    cout << "Ingrese el dia: ";
    cin >> d;
    cout << "Ingrese el mes (1-12): ";
    cin >> m;
    cout << "Ingrese el anio: ";
    cin >> a;
    
    cout << "\nResultado de la conversion: ";
    LITERAL(d, m, a);
    
    // Llamada de prueba del enunciado:
    // cout << "Prueba fija: ";
    // LITERAL(20, 5, 99);
    
    return 0;
}

// Implementación del procedimiento
void LITERAL(int dia, int mes, int anio) {
    // Arreglo con los nombres de los meses. 
    // Dejamos el indice 0 vacio para que el mes 1 coincida con el indice 1.
    string meses[] = {
        "", "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
        "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"
    };
    
    // Validamos que el mes sea correcto
    if (mes < 1 || mes > 12) {
        cout << "[Error: Mes invalido]" << endl;
        return;
    }
    
    // Ajuste para años ingresados con 2 dígitos (ej. 99 -> 1999)
    if (anio < 100) {
        anio += 1900;
    }
    
    // Imprimimos en el formato solicitado
    cout << dia << " de " << meses[mes] << " de " << anio << endl;
}
