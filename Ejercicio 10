#include <iostream>
#include <string>

using namespace std;

// Prototipo del procedimiento
void NUMERO_A_ROMANOS(int n);

int main() {
    int numero;
    
    cout << "--- 10. CONVERSOR A NUMEROS ROMANOS ---" << endl;
    cout << "Ingrese un numero entero (1 - 3999): ";
    cin >> numero;
    
    if (numero < 1 || numero > 3999) {
        cout << "Fuera de rango. Los numeros romanos estandar soportan de 1 a 3999." << endl;
    } else {
        cout << "Equivalente en romano: ";
        NUMERO_A_ROMANOS(numero);
    }
    
    return 0;
}

// Implementacion del procedimiento
void NUMERO_A_ROMANOS(int n) {
    // Arreglos paralelos con los valores base y sus representaciones
    int valores[] = {1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1};
    string simbolos[] = {"M", "CM", "D", "CD", "C", "XC", "L", "XL", "X", "IX", "V", "IV", "I"};
    
    string resultado = "";
    
    // Recorremos los valores desde el mas grande (1000) hasta el mas pequeno (1)
    for (int i = 0; i < 13; i++) {
        // Mientras el numero actual contenga el valor evaluado
        while (n >= valores[i]) {
            resultado += simbolos[i]; // Agregamos el simbolo
            n -= valores[i];          // Descontamos la cantidad
        }
    }
    
    cout << resultado << endl;
}
