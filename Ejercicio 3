#include <iostream>
#include <cmath>

using namespace std;

// Prototipos de las funciones auxiliares
float POTEN(float x, float y);
float FAC(int n);

int main() {
    int x, n;
    float suma = 0.0;
    
    cout << "--- 3. SUMA DE SERIE CONSECUTIVA ---" << endl;
    cout << "Ingrese el valor de X (entero positivo): ";
    cin >> x;
    cout << "Ingrese el limite N (entero positivo): ";
    cin >> n;
    
    // Bucle para sumar cada termino de la serie
    for (int i = 1; i <= n; i++) {
        suma += POTEN(x, i) / FAC(i);
    }
    
    cout << "La suma total de la serie S es: " << suma << endl;
    
    return 0;
}

// Definicion de funciones
float POTEN(float x, float y) {
    return pow(x, y);
}

float FAC(int n) {
    float factorial = 1.0;
    for (int i = 1; i <= n; i++) {
        factorial *= i;
    }
    return factorial;
}
